# ── Banco de dados ────────────────────────────────────────────────────────────
# Dev (SQLite local):
DATABASE_URL=sqlite:///./wecare_parceiros.db
# Prod (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/wecare_parceiros

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=wecare-dev-secret-TROQUE-EM-PRODUCAO
TOKEN_EXPIRE_HOURS=8

# ── E-mail via Resend ─────────────────────────────────────────────────────────
# Se não configurado, notificações são apenas logadas
RESEND_API_KEY=
FROM_EMAIL=WeCare Parceiros <parceiros@wecarehosting.com.br>

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Upload de arquivos ────────────────────────────────────────────────────────
UPLOADS_DIR=./uploads

# ── Bootstrap (criação do primeiro admin via endpoint) ────────────────────────
BOOTSTRAP_TOKEN=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:18790/api/v1
