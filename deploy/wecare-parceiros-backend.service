[Unit]
Description=WeCare Parceiros — Backend FastAPI
After=network.target postgresql.service

[Service]
Type=simple
User=wecare
WorkingDirectory=/opt/wecare-parceiros/backend
EnvironmentFile=/opt/wecare-parceiros/backend/.env
ExecStart=/opt/wecare-parceiros/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 18790
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
